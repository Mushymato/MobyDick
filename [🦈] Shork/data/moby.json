{
  "$schema": "https://smapi.io/schemas/content-patcher.json",
  "Changes": [
    {
      "Action": "EditData",
      "Target": "mushymato.MobyDick/Data",
      "Entries": {
        "{{ModId}}_shork": {
          "SpriteSize": {
            "X": 48,
            "Y": 32
          },
          "WiggleSegmentLength": 8,
          // min horizontal speed
          "SwimVelocityMin": 20,
          // min horizontal speed
          "SwimVelocityMax": 30,
          // min seconds between swim
          "SwimCooldownMin": 3,
          // max seconds between swim
          "SwimCooldownMax": 6,
        },
        "{{ModId}}_whiteshark": {
          "SpriteSize": {
            "X": 64,
            "Y": 32
          },
          "WiggleSegmentLength": 0,
          "SwimAnimation": "{{Range: 0,4}}",
          "SwimAnimationInterval": 125
        },
        "142": {
          "SpriteSize": {
            "X": 96,
            "Y": 32
          },
          "WiggleSegmentLength": 0,
          "HeldItemOriginOffset": "32,0",
          "AquariumTextureOverride": "{{ModId}}\\oarfish",
          "SwimAnimation": "{{Range: 0,6}}",
        },
      }
    }
  ]
}
