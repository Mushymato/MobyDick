{
  "$schema": "https://smapi.io/schemas/content-patcher.json",
  "Changes": [
    {
      "Action": "Load",
      "Target": "Maps/{{ModId}}/open_coop",
      "FromFile": "assets/{{TargetWithoutPath}}.tmx"
    },
    {
      "Action": "Load",
      "Target": "{{ModId}}/tank",
      "FromFile": "assets/{{TargetWithoutPath}}.png"
    },
    {
      "Action": "EditData",
      "Target": "Data/Locations",
      "Entries": {
        "{{ModId}}_open_coop": {
          "DisplayName": "open_coop",
          "DefaultArrivalTile": {
            "X": 2,
            "Y": 10
          },
          "CreateOnLoad": {
            "MapPath": "Maps/{{ModId}}/open_coop",
            "Type": null,
            "AlwaysActive": false
          },
          "CustomFields": {
            "mushymato.MobyDick_FishTanks": "{{ModId}}_Tank1 {{ModId}}_Tank2",
          }
        }
      }
    },
    {
      "Action": "EditData",
      "Target": "mushymato.MobyDick/Tanks",
      "Entries": {
        // debug action mushymato.MobyDick_ReloadFishTank
        "{{ModId}}_Tank1": {
          "DrawInBackground": true,
          "TankBounds": {
            "X": 64,
            "Y": 64,
            "Width": 400,
            "Height": 400,
          },
          "ForegroundTexture": "{{ModId}}/tank",
          "ForegroundSourceRect": {
            "X": 0,
            "Y": 0,
            "Width": 100,
            "Height": 100
          },
          // "ForegroundTargetRect": {
          //   "X": 0,
          //   "Y": 0,
          //   "Width": 100,
          //   "Height": 100
          // },
          "BackgroundTexture": "{{ModId}}/tank",
          "BackgroundSourceRect": {
            "X": 100,
            "Y": 0,
            "Width": 100,
            "Height": 100
          },
          // "BackgroundTargetRect": {
          //   "X": 0,
          //   "Y": 0,
          //   "Width": 400,
          //   "Height": 400
          // },
          // debug action mushymato.MobyDick_ReloadFishTank
          "Fishes": [
            {
              "Id": "{{ModId}}_Fish",
              "ItemId": "ALL_ITEMS (O)",
              "PerItemCondition": "ITEM_CONTEXT_TAG Target category_fish",
              "TakeCount": 10
            },
            {
              "Id": "{{ModId}}_Clay",
              "ItemId": "(O)393"
            }
          ]
        }
      }
    }
  ]
}
